# FortiSIEM AI — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ─────────────────────────────────────────────────────────────────

# Full URL to your FortiSIEM Supervisor (include https://)
FSIEM_HOST=https://your-fortisiem-host

# FortiSIEM username
FSIEM_USER=admin

# FortiSIEM password
FSIEM_PASS=

# Organization name
# Enterprise deployments: use "super"
# Service Provider deployments: use "super" for global access, or a specific org name
FSIEM_ORG=super

# ── Optional ─────────────────────────────────────────────────────────────────

# Set to "true" to enforce SSL certificate validation (recommended for production)
# Set to "false" for self-signed certs (lab/dev environments)
FSIEM_VERIFY_SSL=false

# ── Optional: Ticketing Integrations ─────────────────────────────────────────

# ServiceNow (for /fsiem-ticket)
# SNOW_URL=https://yourinstance.service-now.com
# SNOW_USER=svc_fortisiem
# SNOW_PASS=
# SNOW_ASSIGNMENT_GROUP=SOC

# Jira (for /fsiem-ticket)
# JIRA_URL=https://yourcompany.atlassian.net
# JIRA_USER=your-email@company.com
# JIRA_TOKEN=
# JIRA_PROJECT=SOC

# PagerDuty (for /fsiem-ticket)
# PAGERDUTY_ROUTING_KEY=

# ── Optional: Email Alerts for Scheduled Hunt ─────────────────────────────────

# ALERT_EMAIL=soc-alerts@yourcompany.com
# SMTP_HOST=smtp.yourcompany.com
# SMTP_PORT=25
# SMTP_FROM=fortisiem-ai@yourcompany.com

# ── Optional: Threat Intelligence Enrichment ──────────────────────────────────
# Used by skills/enrichment/ for IP/domain/hash enrichment

# VirusTotal (free: 4 req/min — https://virustotal.com/gui/join-us)
# VT_API_KEY=

# AbuseIPDB (free: 1000 req/day — https://www.abuseipdb.com/register)
# ABUSEIPDB_API_KEY=

# Shodan (paid — https://shodan.io)
# SHODAN_API_KEY=
