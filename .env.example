# FortiSIEM API Configuration
# Copy this file to .env and fill in your values.

# Full URL to FortiSIEM Supervisor (include https://)
FSIEM_HOST=https://your-fortisiem-host

# FortiSIEM username
FSIEM_USER=admin

# FortiSIEM password
FSIEM_PASS=yourpassword

# Organization name ("super" for Enterprise deployments; org name for Service Provider)
FSIEM_ORG=super

# SSL certificate verification ("true" for production with valid certs, "false" to skip)
FSIEM_VERIFY_SSL=false

# Auth format override (leave empty for default org/user:password format)
# Set to "user_org" only for legacy FortiSIEM versions that require user/org:password
# FSIEM_AUTH_FORMAT=
